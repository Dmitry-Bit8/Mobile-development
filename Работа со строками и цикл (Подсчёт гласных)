void main() {
  String word = "Flutter";
  int vowelCount = countVowels(word);

  print("Слово: $word");
  print("Гласных букв: $vowelCount");
}

int countVowels(String word) {
  int count = 0;
  String vowels = "aeiouyAEIOUY";
  for (int i = 0; i < word.length; i++) {
    if (vowels.contains(word[i])) {
      count++;
    }
  }
  return count;
}
